# Public hostname. Create an A record pointing this name to the VPS IPv4.
API_DOMAIN=api.orbitways.com

# Space-Track credentials. Never commit the populated .env file.
SPACETRACK_EMAIL=replace-me
SPACETRACK_PASSWORD=replace-me

# Long random bearer token expected by the frontend.
ORBITWAYS_API_KEY=replace-with-at-least-32-random-bytes

# CDM archive cadence and retrieval window.
CDM_SYNC_INTERVAL_HOURS=8
CDM_SYNC_INITIAL_LOOKBACK_DAYS=30
CDM_SYNC_OVERLAP_HOURS=24
CDM_SYNC_MAX_LOOKBACK_DAYS=30
CDM_SYNC_MAX_RECORDS=50000

# Daily SQLite backup policy.
SQLITE_BACKUP_INTERVAL_HOURS=24
SQLITE_BACKUP_RETENTION_DAYS=30

LOG_LEVEL=INFO
